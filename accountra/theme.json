    "styles": {
        "spacing": {
            "blockGap": "1.2rem"
        },
        "blocks": {
            "core/post-content": {
                "spacing": {
                    "margin": {
                        "top": "0px"
                    }
                }
            }
        },
        "elements": {
            "button": {
                "color": {
                    "background": "var:preset|color|secondary",
                    "text": "var:preset|color|primary"
                }
            },
            "link": {
                "color": {
                    "text": "var:preset|color|secondary"
                },
                ":hover": {
                    "color": {
                        "text": "var:preset|color|primary"
                    }
                }
            },
            "heading": {
                "color": {
                    "text": "var:preset|color|primary"
                }
            }
        },
        "color": {
            "text": "var:preset|color|forth",
            "background": "var(--wp--preset--color--white)"
        }
    },
